# Postgres connection — matches docker-compose.yml on host port 3141
DATABASE_URL=postgresql://cooks:cooks_dev@localhost:3141/cooks_assistant

# Clerk — get from https://dashboard.clerk.com (use a dev instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: Cloudinary for image uploads. Falls back to local storage when unset.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Test user for @playwright-debugger walkthroughs.
# Create via Clerk Backend API:
#   curl -X POST https://api.clerk.com/v1/users \
#     -H "Authorization: Bearer $CLERK_SECRET_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{"email_address":["test@cooksassistant.dev"],"password":"<strong>"}'
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
# TEST_USER_ID=
